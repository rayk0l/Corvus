# ============================================
#  Endpoint Security Scanner - .gitignore
# ============================================

# --- Build artifacts ---
dist/
build/
*.spec.bak

# --- Nuitka build artifacts ---
*.build/
*.onefile-build/
*.dist/

# --- Executables (corvus.exe tracked in repo) ---
*.exe
!corvus.exe

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
pip-log.txt

# --- Virtual environments ---
venv/
.venv/
env/
.env/

# --- IDE ---
.vscode/
.cursor/
.idea/
*.swp
*.swo
*~
.project
.settings/

# --- OS files ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*

# --- Scan output (reports & logs) ---
report_*.html
report_*.json
scan_log_*.txt
*.log

# --- Environment files ---
.env
.env.local

# --- Claude Code session data ---
.claude/

# --- Build tool temp ---
*.manifest

# --- Debug symbols ---
*.pdb

# --- Test cache ---
.pytest_cache/

# --- Documentation build ---
docs/node_modules/
